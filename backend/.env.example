# Sen'Analytics Mission Control — Backend Configuration
# Copy to .env and fill in values.

# ── Server ──
HOST=0.0.0.0
PORT=8000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL (for workflow/execution persistence) ──
DATABASE_URL=postgresql://senanalytics:***@localhost:5432/senanalytics

# ── Redis (for event bus streaming) ──
REDIS_URL=redis://localhost:6379

# ── Neo4j (for knowledge graph) ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=senanalytics_dev

# ── LLM — OpenAI-compatible API ──
# Set LLM_API_KEY to enable real LLM agent calls (required)
# Without it, agents return simulated demo data
LLM_API_KEY=***
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_TEMPERATURE=0.3
