# Sen'Analytics Mission Control — Backend Configuration
# Copy to .env and fill in values.

# Server
HOST=0.0.0.0
PORT=8000

# Redis (for event bus streaming)
REDIS_URL=redis://localhost:6379

# PostgreSQL (for workflow/execution persistence — Phase 3+)
DATABASE_URL=postgresql://senanalytics:senanalytics_dev@localhost:5432/senanalytics

# Neo4j (for knowledge graph — Phase 5+)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=senanalytics_dev
